{
  "name": "obsidian-goldilocks-essentials",
  "version": "0.1.1",
  "description": "A curated kit of small, opt-in UX upgrades for Obsidian.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "version": "node version-bump.mjs && git add manifest.json versions.json"
  },
  "keywords": [
    "obsidian",
    "plugin",
    "utilities"
  ],
  "author": "sachio222",
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "devDependencies": {
    "@types/node": "^20",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.23.0",
    "obsidian": "latest",
    "tslib": "^2.6.0",
    "typescript": "^5.5.0"
  }
}
